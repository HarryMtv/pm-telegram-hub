{
  "name": "pm-telegram-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram Aggregator — Integration Service + Bot + Mini App over ClickUp / Wrike / Jira",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "migrate": "tsx scripts/migrate.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "tunnel": "tsx scripts/tunnel.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "bullmq": "^5.80.9",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "grammy": "^1.30.0",
    "ioredis": "^5.4.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.0",
    "prettier": "^3.3.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "shadcn": "^4.13.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
